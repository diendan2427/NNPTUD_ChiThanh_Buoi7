{
  "info": {
    "name": "NNPTUD Reservations API",
    "_postman_id": "8a34dc0c-7b95-47da-9ce1-1b2e4c88a001",
    "description": "Collection test cac API reservation theo de bai.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "username",
      "value": "user1"
    },
    {
      "key": "password",
      "value": "123456"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "reservationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login thanh cong', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const token = pm.response.text();",
              "pm.collectionVariables.set('token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Get products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ]
        }
      }
    },
    {
      "name": "3. Add item to cart",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"{{productId}}\",\n  \"quantity\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/carts/add-items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "carts",
            "add-items"
          ]
        }
      }
    },
    {
      "name": "4. Get cart",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/carts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "carts"
          ]
        }
      }
    },
    {
      "name": "5. Reserve items",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"product\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/reservations/reserveItems",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "reserveItems"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Reserve items thanh cong', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.collectionVariables.set('reservationId', jsonData._id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Reserve a cart",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations/reserveACart",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "reserveACart"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Reserve cart thanh cong', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.collectionVariables.set('reservationId', jsonData._id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. Get all reservations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations"
          ]
        }
      }
    },
    {
      "name": "8. Get one reservation",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations/{{reservationId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "{{reservationId}}"
          ]
        }
      }
    },
    {
      "name": "9. Cancel reservation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/reservations/cancelReserve/{{reservationId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reservations",
            "cancelReserve",
            "{{reservationId}}"
          ]
        }
      }
    }
  ]
}
